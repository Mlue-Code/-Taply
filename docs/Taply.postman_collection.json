{
  "info": {
    "name": "Taply API",
    "description": "Complete API collection for Taply MVP - Design feedback platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "API base URL (change for production)"
    },
    {
      "key": "firebaseToken",
      "value": "PASTE_YOUR_FIREBASE_TOKEN_HERE",
      "type": "string",
      "description": "Firebase ID token for authenticated endpoints"
    },
    {
      "key": "designId",
      "value": "PASTE_REAL_DESIGN_ID_HERE",
      "type": "string",
      "description": "Real design ID for feedback testing"
    },
    {
      "key": "shareableId",
      "value": "PASTE_REAL_SHAREABLE_ID_HERE",
      "type": "string",
      "description": "Real shareable ID for public view testing"
    }
  ],
  "item": [
    {
      "name": "Designs",
      "description": "Endpoints for managing design uploads and public access",
      "item": [
        {
          "name": "Upload Design",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": [],
                  "description": "Image file (max 10MB) - JPG, PNG, GIF, WEBP"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/designs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "designs"]
            },
            "description": "Upload a new design. Requires Firebase Authentication. Rate limited to 20 requests per hour per IP."
          },
          "response": [
            {
              "name": "Success - 201 Created",
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"id\": \"abc123xyz\",\n  \"shareableId\": \"ckpqr5w8x000abc\",\n  \"imageUrl\": \"https://res.cloudinary.com/taply/image/upload/v1234/design.jpg\",\n  \"createdAt\": \"2025-01-15T10:30:00.000Z\"\n}"
            },
            {
              "name": "Error - 401 Missing Auth",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"error\": \"UNAUTHORIZED\",\n  \"message\": \"Authorization header missing\"\n}"
            },
            {
              "name": "Error - 401 Invalid Token",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"error\": \"UNAUTHORIZED\",\n  \"message\": \"Invalid or expired token\"\n}"
            },
            {
              "name": "Error - 400 No File",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"VALIDATION_ERROR\",\n  \"message\": \"No image file provided. Use field name \\\"image\\\"\"\n}"
            },
            {
              "name": "Error - 400 Invalid File Type",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"VALIDATION_ERROR\",\n  \"message\": \"Only image files are allowed\"\n}"
            },
            {
              "name": "Error - 429 Rate Limit",
              "status": "Too Many Requests",
              "code": 429,
              "body": "{\n  \"error\": \"INTERNAL_ERROR\",\n  \"message\": \"Too many requests. Please try again later.\"\n}"
            }
          ]
        },
        {
          "name": "Get Design by ShareableId",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/designs/{{shareableId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "designs", "{{shareableId}}"]
            },
            "description": "Retrieve a design and all its feedback by shareable ID. Public endpoint - no authentication required."
          },
          "response": [
            {
              "name": "Success - 200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"design\": {\n    \"id\": \"abc123xyz\",\n    \"shareableId\": \"ckpqr5w8x000abc\",\n    \"imageUrl\": \"https://res.cloudinary.com/taply/image/upload/v1234/design.jpg\",\n    \"publicId\": \"taply/designs/abc\",\n    \"creatorUid\": \"user-uid-123\",\n    \"createdAt\": \"2025-01-15T10:30:00.000Z\"\n  },\n  \"feedback\": [\n    {\n      \"id\": \"feedback1\",\n      \"comment\": \"Looking great!\",\n      \"x\": 0.5,\n      \"y\": 0.5,\n      \"createdAt\": \"2025-01-15T12:00:00.000Z\"\n    }\n  ]\n}"
            },
            {
              "name": "Error - 404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"error\": \"NOT_FOUND\",\n  \"message\": \"Design with shareableId \\\"abc123\\\" not found\"\n}"
            },
            {
              "name": "Error - 400 Missing ShareableId",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"VALIDATION_ERROR\",\n  \"message\": \"shareableId is required\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Feedback",
      "description": "Endpoints for submitting feedback on designs",
      "item": [
        {
          "name": "Create Feedback - Valid",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"designId\": \"{{designId}}\",\n  \"comment\": \"This looks great! Maybe try a brighter color here.\",\n  \"x\": 0.45,\n  \"y\": 0.78\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["api", "feedback"]
            },
            "description": "Submit feedback on a design. Public endpoint. Rate limited to 10 requests per minute per IP."
          },
          "response": [
            {
              "name": "Success - 201 Created",
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"id\": \"ckpqr5w8x000abc\",\n  \"comment\": \"This looks great! Maybe try a brighter color here.\",\n  \"x\": 0.45,\n  \"y\": 0.78,\n  \"createdAt\": \"2025-01-15T12:30:00.000Z\"\n}"
            }
          ]
        },
        {
          "name": "Create Feedback - Empty Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"designId\": \"{{designId}}\",\n  \"comment\": \"\",\n  \"x\": 0.5,\n  \"y\": 0.5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["api", "feedback"]
            },
            "description": "Test validation: empty comment should return 400"
          },
          "response": [
            {
              "name": "Error - 400 Empty Comment",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"VALIDATION_ERROR\",\n  \"message\": \"comment: comment cannot be empty\"\n}"
            }
          ]
        },
        {
          "name": "Create Feedback - Invalid Coordinates",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"designId\": \"{{designId}}\",\n  \"comment\": \"Test\",\n  \"x\": 2,\n  \"y\": -1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["api", "feedback"]
            },
            "description": "Test validation: coordinates outside 0-1 range"
          },
          "response": [
            {
              "name": "Error - 400 Invalid Coordinates",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"VALIDATION_ERROR\",\n  \"message\": \"x: x must be between 0 and 1, y: y must be between 0 and 1\"\n}"
            }
          ]
        },
        {
          "name": "Create Feedback - Design Not Found",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"designId\": \"non-existent-id\",\n  \"comment\": \"Test\",\n  \"x\": 0.5,\n  \"y\": 0.5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["api", "feedback"]
            },
            "description": "Test: design with this ID doesn't exist"
          },
          "response": [
            {
              "name": "Error - 404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"error\": \"NOT_FOUND\",\n  \"message\": \"Design with id \\\"non-existent-id\\\" not found\"\n}"
            }
          ]
        }
      ]
    }
  ]
}